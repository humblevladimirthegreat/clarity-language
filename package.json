{
  "name": "clarity-language",
  "version": "0.1.0",
  "description": "Clarity Language tooling — ANTLR parsers and agent-facing APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "antlr-ng -Dlanguage=TypeScript -l false -o src/generated --exact-output-dir true grammar/SentenceParser.g4 grammar/WordParser.g4",
    "build": "npm run generate && tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "parse": "tsx src/cli.ts",
    "convert-ngsl": "tsx scripts/convert-ngsl.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "antlr4ng": "^3.0.16"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "antlr-ng": "^1.0.10",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
